# Local development environment variables
# Copy this to .env and update values for your environment.
# Do not commit the actual .env file with real credentials.

# Backend database connection
DATABASE_URL=postgresql://<DB_USER>:<DB_PASSWORD>@localhost:5432/<DB_NAME>?sslmode=disable

# Backend server configuration
PORT=8080
CORS_ORIGINS=http://localhost:5173

# Docker/Postgres password (used by docker-compose)
POSTGRES_PASSWORD=<DB_PASSWORD>

# Frontend service URLs
VITE_API_BASE_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080/ws/alerts
